#!/bin/bash

NOTI_ID=9999

obs-cmd recording start 2>&1 | while IFS= read -r line; do
  if echo "$line" | grep -q "Connection attempt 1 failed"; then
    notify-send -t 2000 -u critical "OBS" "❌ OBS not running"
    pkill -f "obs-cmd recording"
    exit 1
  fi
done

if [ $? -eq 0 ]; then
  notify-send -t 2000 "OBS" "🟢 Recording started"
  sleep 2
  notify-send -t 0 --replace-id=$NOTI_ID "🟢 Recording"
else
  notify-send -t 2000 -u critical "OBS" "❌ Failed to start recording"
  exit 1
fi
